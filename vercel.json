{
  "rewrites": [
    { "source": "/sitemap.xml",                    "destination": "/sitemap.xml" },
    { "source": "/robots.txt",                     "destination": "/robots.txt" },
    { "source": "/manifest.json",                  "destination": "/manifest.json" },
    { "source": "/googlee9eb4e65cfb7b8c4.html",    "destination": "/googlee9eb4e65cfb7b8c4.html" },
    { "source": "/sw.js",                          "destination": "/sw.js" },
    { "source": "/icon-192.png",                   "destination": "/icon-192.png" },
    { "source": "/icon-512.png",                   "destination": "/icon-512.png" },
    { "source": "/favicon.png",                    "destination": "/favicon.png" },
    { "source": "/(.*)",                           "destination": "/" }
  ],
  "headers": [
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Content-Type",   "value": "application/manifest+json" },
        { "key": "Cache-Control",  "value": "no-cache" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type",   "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control",  "value": "no-cache" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type",   "value": "text/plain" },
        { "key": "Cache-Control",  "value": "no-cache" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control",          "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Permissions-Policy",   "value": "usb=*, geolocation=*" },
        { "key": "X-Content-Type-Options","value": "nosniff" },
        { "key": "X-Frame-Options",       "value": "DENY" },
        { "key": "Referrer-Policy",       "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
